<Window x:Class="подобие_echo_room.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:подобие_echo_room"
        mc:Ignorable="d"
        Title="ECHO//ROOM" Height="620" Width="1060"
        MinHeight="560" MinWidth="960"
        Background="#0D1016"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="660"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="#3B4354"
                BorderThickness="1"
                Background="#121722"
                Padding="10">
            <Canvas x:Name="GameCanvas"
                    Width="624"
                    Height="432"
                    Focusable="False"/>
        </Border>

        <Grid Grid.Column="1" Margin="18,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="ECHO//ROOM"
                           Foreground="#E8EEF8"
                           FontSize="32"
                           FontWeight="Bold"/>
                <TextBlock Text="Психологическая puzzle-game"
                           Foreground="#8E9AAF"
                           FontSize="14"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,18,0,14"
                    Background="#151C28"
                    BorderBrush="#2C3546"
                    BorderThickness="1"
                    Padding="14">
                <StackPanel>
                    <TextBlock x:Name="TimeText"
                               Foreground="#E8EEF8"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusText"
                               Foreground="#C6D0DF"
                               FontSize="14"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"/>
                    <TextBlock Foreground="#8E9AAF"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"
                               Text="WASD/стрелки - движение, E - действие, R - заново. Пульт прошлого должен нажать эхо, пульт настоящего - игрок."/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="#151C28"
                    BorderBrush="#2C3546"
                    BorderThickness="1"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Таймлайн записи"
                               Foreground="#E8EEF8"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <ListBox x:Name="TimelineList"
                             Background="#0F141D"
                             BorderBrush="#263043"
                             Foreground="#C6D0DF"
                             FontFamily="Consolas"
                             FontSize="13"/>
                </DockPanel>
            </Border>

            <Button Grid.Row="3"
                    Content="Начать заново"
                    Height="40"
                    Margin="0,14,0,0"
                    Click="RestartButton_Click"
                    Background="#273246"
                    BorderBrush="#536079"
                    Foreground="#E8EEF8"/>
        </Grid>
    </Grid>
</Window>
