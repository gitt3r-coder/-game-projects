<Window x:Class="симулятор_NPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AI NPC Simulator" Height="720" Width="1180" MinHeight="650" MinWidth="980"
        Background="#101820" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#18242E" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#21313D" />
        <SolidColorBrush x:Key="AccentBrush" Color="#65D6AD" />
        <SolidColorBrush x:Key="TextBrush" Color="#F1F6F4" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A9BBB5" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F7FBFA" />
            <Setter Property="Background" Value="#2A5462" />
            <Setter Property="BorderBrush" Value="#457581" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#111B22" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#314754" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="AI NPC Simulator" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Маленький город, где жители говорят, помнят события и реагируют на игрока"
                           Foreground="{StaticResource MutedTextBrush}" FontSize="14" Margin="0,3,0,0" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Background="#24323B" BorderBrush="#38515F" BorderThickness="1" Padding="12,8" Margin="8,0,0,0">
                    <TextBlock x:Name="ClockText" FontSize="16" FontWeight="SemiBold" />
                </Border>
                <Button Content="Пауза" Click="PauseButton_Click" Margin="10,0,0,0" MinWidth="92" x:Name="PauseButton" />
                <Button Content="Следующий час" Click="NextHourButton_Click" Margin="8,0,0,0" MinWidth="120" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="1.25*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="#314754" BorderThickness="1" Padding="14" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Карта города" FontSize="20" FontWeight="SemiBold" DockPanel.Dock="Left" />
                        <TextBlock x:Name="WeatherText" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                    </DockPanel>

                    <Grid Grid.Row="1" Background="#13222A" ClipToBounds="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Margin="8" Background="#314D3D" BorderBrush="#5C7C66" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Парк" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="место встреч" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" Margin="8" Background="#35434B" BorderBrush="#60747D" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Площадь" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="новости города" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="2" Margin="8" Background="#4C3D33" BorderBrush="#806A57" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Кафе" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="слухи и отдых" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" Margin="8" Background="#384B5B" BorderBrush="#637A8F" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Библиотека" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="тихие знания" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Margin="8" Background="#594842" BorderBrush="#8C7369" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Рынок" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="торговля" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="2" Margin="8" Background="#2E4F58" BorderBrush="#5E8A94" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Мастерская" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="ремонт и работа" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="8" Background="#243846" BorderBrush="#415C6D" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Улица игрока" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="сюда приходят NPC, если хотят поговорить" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Canvas Grid.RowSpan="3" Grid.ColumnSpan="3" IsHitTestVisible="False">
                            <Ellipse x:Name="MarkerMira" Width="24" Height="24" Fill="#65D6AD" Stroke="#EFFCF8" StrokeThickness="2" />
                            <Ellipse x:Name="MarkerAnton" Width="24" Height="24" Fill="#F0B35E" Stroke="#FFF7E7" StrokeThickness="2" />
                            <Ellipse x:Name="MarkerLera" Width="24" Height="24" Fill="#79A7FF" Stroke="#F1F6FF" StrokeThickness="2" />
                            <Ellipse x:Name="MarkerBoris" Width="24" Height="24" Fill="#E86B74" Stroke="#FFF0F0" StrokeThickness="2" />
                        </Canvas>
                    </Grid>

                    <Border Grid.Row="2" Background="{StaticResource PanelAltBrush}" BorderBrush="#36505D" BorderThickness="1" Padding="12" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Действия игрока" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <WrapPanel>
                                <Button Content="Поздороваться" Click="GreetButton_Click" />
                                <Button Content="Помочь NPC" Click="HelpButton_Click" />
                                <Button Content="Рассказать новость" Click="NewsButton_Click" />
                                <Button Content="Создать проблему" Click="TroubleButton_Click" />
                                <Button Content="Спросить о городе" Click="AskButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="#314754" BorderThickness="1" Padding="14" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1.05*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Жители" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ListBox x:Name="NpcListBox" Grid.Row="1" SelectionChanged="NpcListBox_SelectionChanged" DisplayMemberPath="DisplayName" />

                    <TextBlock Grid.Row="2" Text="Память выбранного NPC" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,8" />
                    <ListBox x:Name="MemoryListBox" Grid.Row="3" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="#314754" BorderThickness="1" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1.1*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Диалог" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <Border Grid.Row="1" Background="{StaticResource PanelAltBrush}" BorderBrush="#36505D" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock x:Name="SelectedNpcNameText" FontSize="17" FontWeight="SemiBold" />
                            <TextBlock x:Name="SelectedNpcStateText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            <ProgressBar x:Name="TrustBar" Height="10" Minimum="0" Maximum="100" Margin="0,10,0,0" Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="DialogueListBox" Grid.Row="2" />

                    <TextBlock Grid.Row="3" Text="Журнал событий" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,8" />
                    <ListBox x:Name="EventLogListBox" Grid.Row="4" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
