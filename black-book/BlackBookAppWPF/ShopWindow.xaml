<Window x:Class="BlackBookAppWPF.ShopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛒 МАГАЗИН" Height="430" Width="500"
        WindowStartupLocation="CenterOwner" 
        Background="#FF2D2D37"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🛒 МАГАЗИН МАГИЧЕСКИХ СВИТКОВ" 
                   FontSize="18" FontWeight="Bold" 
                   Foreground="Gold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="#FF1E1E2A" CornerRadius="10" 
                Padding="15" Margin="0,0,0,20">
            <TextBlock x:Name="lblGold" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="Gold" 
                       HorizontalAlignment="Center">
                💰 Ваше золото: 0
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="2">
            <Button x:Name="btnBooster"
                    Content="📦 Малый бустер (3 карты) - 100 💰" 
                    Height="58" FontSize="14" FontWeight="Bold"
                    Background="#FF5050C8" Foreground="White"
                    Click="BtnBooster_Click" Margin="0,6"/>

            <Button x:Name="btnBattleBooster"
                    Content="🔥 Боевой набор (6 карт) - 230 💰" 
                    Height="58" FontSize="14" FontWeight="Bold"
                    Background="#FF9A4F34" Foreground="White"
                    Click="BtnBattleBooster_Click" Margin="0,6"/>

            <Button x:Name="btnLegendChance"
                    Content="✨ Редкий фолиант (10 карт) - 420 💰" 
                    Height="58" FontSize="14" FontWeight="Bold"
                    Background="#FF7B4BD2" Foreground="White"
                    Click="BtnLegendChance_Click" Margin="0,6"/>
        </StackPanel>

        <Button Grid.Row="3" Content="ЗАКРЫТЬ" 
                Height="40" FontSize="12"
                Background="#FF606060" Foreground="White"
                Click="BtnClose_Click" Margin="0,20"/>
    </Grid>
</Window>
