<UserControl x:Class="BlackBookAppWPF.Controls.CardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="212" Height="342">

    <UserControl.Resources>
        <Storyboard x:Key="GlowEffect">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="1.05" Duration="0:0:0.3" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="1.05" Duration="0:0:0.3" AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>

        <Storyboard x:Key="FlipEffect">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             From="0" To="360" Duration="0:0:0.5"/>
        </Storyboard>

        <Storyboard x:Key="OpenPackEffect">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="CardBorder" CornerRadius="12" BorderThickness="2" Margin="5"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform/>
        </Border.RenderTransform>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#FF2D2D37"/>
                <Setter Property="BorderBrush" Value="Gray"/>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="178"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#EE15151D" CornerRadius="10,10,0,0" Padding="8">
                <Grid>
                    <TextBlock x:Name="CardName" FontSize="14" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Left"
                               TextTrimming="CharacterEllipsis" MaxWidth="138"/>
                    <Border Background="#EE000000" CornerRadius="15" Padding="6,2" 
                            HorizontalAlignment="Right">
                        <TextBlock x:Name="CardCost" FontSize="12" FontWeight="Bold" 
                                   Foreground="Cyan" Text="💧 0"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="10,9,10,6" Background="#FF101018" CornerRadius="9"
                    BorderBrush="#44FFFFFF" BorderThickness="1">
                <Image x:Name="CardImage" Stretch="UniformToFill" 
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <Grid Grid.Row="2" Margin="10,0,10,3">
                <TextBlock x:Name="CardFaction" FontSize="10" Foreground="#FFC9D4E8"
                           HorizontalAlignment="Left" FontWeight="SemiBold"/>
                <Border Background="#332DD4BF" CornerRadius="8" Padding="6,1"
                        HorizontalAlignment="Right">
                    <TextBlock x:Name="CardEffect" FontSize="10" Foreground="#FFBFFAF2"
                               FontWeight="Bold"/>
                </Border>
            </Grid>

            <TextBlock x:Name="CardDescription" Grid.Row="3" FontSize="10" 
                       Foreground="#FFD6D6DA" TextWrapping="Wrap" 
                       Margin="10,2,10,0" TextAlignment="Center" 
                       MaxHeight="42" TextTrimming="CharacterEllipsis"/>

            <TextBlock x:Name="CardQuote" Grid.Row="3" FontSize="9" FontStyle="Italic"
                       Foreground="#FF8D92A3" TextWrapping="Wrap"
                       Margin="10,43,10,0" TextAlignment="Center"
                       MaxHeight="26" TextTrimming="CharacterEllipsis"/>

            <Border Grid.Row="4" Background="#EE15151D" CornerRadius="0,0,10,10" Padding="8">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock x:Name="CardPower" FontSize="12" FontWeight="Bold" 
                                   Foreground="Orange" Text="⚔️ 0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="CardStars" FontSize="10" Foreground="Gold"/>
                        <TextBlock x:Name="CardType" FontSize="10" Foreground="#FF9AA0AA" Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
