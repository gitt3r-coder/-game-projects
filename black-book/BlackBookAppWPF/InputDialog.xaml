<Window x:Class="BlackBookAppWPF.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод" Height="180" Width="400"
        WindowStartupLocation="CenterOwner" 
        Background="#FF2D2D37"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="lblPrompt" Text="Введите текст:" 
                   Foreground="White" FontSize="14" Margin="5"/>

        <TextBox x:Name="txtInput" Grid.Row="1" 
                 Margin="5" Padding="8" 
                 Background="White" FontSize="14"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="5">
            <Button Content="OK" Width="80" Height="35" 
                    Margin="5" Click="Ok_Click" 
                    Background="#FF4A4A56" Foreground="White"/>
            <Button Content="Отмена" Width="80" Height="35" 
                    Margin="5" Click="Cancel_Click"
                    Background="#FF4A4A56" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>